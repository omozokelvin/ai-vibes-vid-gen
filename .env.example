# Application
PORT=3000
NODE_ENV=development

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Video/Image Generation APIs

# Kling AI - REAL AI VIDEO GENERATION (text-to-video)
# Sign up at: https://klingai.com/global/dev
# Get Access Key and Secret Key from the developer portal
# Generates actual AI videos, not just images with zoom effects
# Quality: Excellent | Speed: 1-3 min per clip | Cost: Paid (credits)
# KLING_ACCESS_KEY=your_kling_access_key_here
# KLING_SECRET_KEY=your_kling_secret_key_here
# KLING_MODEL=kling-v2-master  # Options: kling-v1, kling-v1-6, kling-v2-master, kling-v2-1-master, kling-v2-5-turbo, kling-v2-6
# KLING_MODE=std               # Options: std (standard), pro (higher quality)

# Replicate API (Paid but reliable)
# Get API key at: https://replicate.com/account/api-tokens
# Pricing: ~$0.003 per image (~300 images for $1)
# Leave empty to use free Pollinations.ai instead
# REPLICATE_API_TOKEN=your_replicate_api_token_here

# Hugging Face API (DEPRECATED - models return 410 errors as of Feb 2026)
# Only use if HF re-enables free image generation
# HUGGINGFACE_API_KEY=your_huggingface_api_key_here
# HUGGINGFACE_IMAGE_MODEL=runwayml/stable-diffusion-v1-5

# YouTube API (Google)
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_REDIRECT_URI=http://localhost:3000/auth/youtube/callback
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token

# TikTok API
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token

# Redis for BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379

# File Storage
TEMP_DIR=./temp
DEBUG_DIR=./debug
